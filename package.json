{
    "name": "screepers-steamless-client",
    "description": "A browser client for Screeps",
    "type": "module",
    "version": "1.20.1",
    "bin": {
        "screepers-steamless-client": "dist/clientApp.js"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "rollup -c",
        "dev": "rollup -cw",
        "format": "prettier --write 'src/**/*.ts'",
        "lint": "eslint src/**/*.ts",
        "prestart": "npm run build",
        "start": "node dist/clientApp.js",
        "prepare": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/screepers/steamless-client.git"
    },
    "author": "laverdet",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/screepers/steamless-client/issues"
    },
    "homepage": "https://github.com/screepers/steamless-client#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/http-proxy": "1.17.17",
        "@types/js-beautify": "1.14.3",
        "@types/koa": "2.15.0",
        "@types/koa-conditional-get": "2.0.4",
        "@types/node": "25.3.5",
        "@types/winreg": "^1.2.36",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "rollup": "^4.59.0",
        "rollup-plugin-shebang-bin": "^0.1.0",
        "tslib": "^2.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "@ladjs/koa-views": "^9.0.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "ejs": "^5.0.1",
        "http-proxy": "1.18.1",
        "http-proxy-middleware": "^3.0.5",
        "js-beautify": "1.15.4",
        "jszip": "^3.10.1",
        "koa": "3.1.2",
        "koa-conditional-get": "3.0.0",
        "node-fetch": "^3.3.2",
        "winreg": "^1.2.5"
    }
}
