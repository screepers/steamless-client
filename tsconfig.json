{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "lib": [
      "esnext",
      "dom"
    ],
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "node16",
    "noImplicitOverride": true,
    "sourceMap": false,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
